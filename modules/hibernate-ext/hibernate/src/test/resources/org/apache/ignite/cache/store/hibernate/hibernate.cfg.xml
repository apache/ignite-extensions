<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <!-- Show SQL. -->
        <property name="show_sql">true</property>

        <!-- Database connection settings (private in-memory database). -->
        <!-- H2 1.x: create table via INIT to avoid hbm2ddl.auto=update (sequence metadata extraction fails on H2 1.x). -->
        <property name="connection.url">
            jdbc:h2:mem:example;DB_CLOSE_DELAY=-1;INIT=CREATE TABLE IF NOT EXISTS ENTRIES (key VARBINARY PRIMARY KEY, val VARBINARY)
        </property>

        <!-- H2 1.x: 'start_value' column missing in INFORMATION_SCHEMA.SEQUENCES — disable schema migration. -->
        <property name="hbm2ddl.auto">validate</property>

        <!-- H2 dialect. -->
        <property name="hibernate.dialect">org.hibernate.dialect.H2Dialect</property>

        <!-- Mappings. -->
        <mapping resource="org/apache/ignite/cache/store/hibernate/CacheHibernateBlobStoreEntry.hbm.xml"/>
    </session-factory>
</hibernate-configuration>
